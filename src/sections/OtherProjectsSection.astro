---
import ProjectCard from '../components/project/ProjectCard'
---

<section id="other-projects" data-main-section class = "h-screen snap-start snap-always" >
    <div class = "h-full overflow-hidden flex flex-col pt-24">
        <div class = "shrink-0 mx-8 md:mx-24 flex items-center">
            <h1 class = "whitespace-nowrap font-bold text-xl md:text-2xl">4. Other Projects</h1>
            <div class = "w-full bg-gray-300 h-px ml-2"></div>
        </div>
        <div data-section-scroll-body class = "flex-1 min-h-0 overflow-y-auto">
            <div class = " 
                grid grid-cols-1
                pt-4 pb-8
                sm:grid-cols-1
                md:grid-cols-2
                mx-8 md:mx-24
                gap-4
                ">
                
                <ProjectCard
                    client:visible
                    title = "HK Car Park Revenue Analysis"
                    content = {`A Node.js tool that fetches real-time data from DATA.GOV.HK to analyze car park occupancy. 
                    It visualizes the relationship between parking rates, EV charging availability, and vacancy rates across HK districts.`}
                    tagNames = {["Node.js", "JavaScript", "DATA.GOV.HK API", "Data Visualization", "Chart.js"]}
                    gitHref = {"https://github.com/nthGH1030/CarParkRevenue.git"}
                />
                <ProjectCard
                    client:visible
                    title = "Landlord Provision Chatbot"
                    content = {`A chatbot that recommand industry standard premise provision for 
                    leasing commercial real estate, such as retail, restaurant`}
                    tagNames = {["TypeScript" , "openAI" , "Azure"]}
                    href = {"placeholder"}
                    gitHref = {"placeholder"}
                />
                <ProjectCard
                    client:visible
                    title = "LLM-Token-Checker"
                    content = {`A chrome extension that tracks the amount of free token you have
                    and refresh time for LLM chatbot such as POE.com, Grok`}
                    tagNames = {["JavaScript" , "React" , "Chrome Extension"]}
                    href = {"https://github.com/nthGH1030/LLM-Token-Tracker.git"}
                    gitHref = {"https://github.com/nthGH1030/LLM-Token-Tracker.git"}
                />
                <div id="payment-form-filler">
                    <ProjectCard
                        client:visible
                        title = "Payment Form filler"
                        content = {`An desktop Application that takes in a master table in an excel file,
                        extract its content, check the format and paste onto a separate excel form`}
                        tagNames = {["JavaScript" , "Electron", "React", "CSS" , "HTML"]}
                        href = {"placeholder"}
                        gitHref = {"placeholder"}
                    />
                </div>
            </div>
        </div>
    </div>
</section>