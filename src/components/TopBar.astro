---
// An icon button on top left
    // move when click
    //link to the page
// line up 4 buttons
    // on click, croll the page to certain portion
// a special button that link to a resume

import "../styles/global.css";
import HamMenu from "./HamMenu";
---


<div class = 
    "z-10 fixed top-0 w-full text-xs md:text-base px-8 py-8 md:pt-8
    topbar-slide-in">
    {/* This is the desktop version */ }
    <div class = "hidden md:block">
        <nav class = "flex justify-between">
            <div class = "flex items-center gap-2 md:gap-5 md:ml-8">
                <a href = "#icon">
                    <img src = "" alt = "icon"/>
                </a>
                <p class = "">My Name</p>
            </div>
            <div class = "flex gap-8 items-center justify-end text-base md:mr-8">
                <a href = "#about" class = "nav-link" >About</a>
                <a href = "#experience" class = "nav-link" >Experience</a>
                <a href = "#work" class = "nav-link" >Work</a>
                <a href = "#contact" 
                class = "nav-link inline-block p-2 rounded-sm
                        hover:-translate-y-1 hover:-translate-x-1
                        border-b-4 border-r-4 border-l-1 border-t-1 border-transparent 
                        hover:border-b-4 hover:border-r-4 hover:border-red-500 
                        cursor-pointer transition will-change-transform " >
                        Contact</a>
                
                
            </div>
        </nav>
    </div>
    {/* This is the mobile version */ }
    <div class = "md:hidden">
        <nav class = "flex justify-between mx-2 sm:mx-4 ">
            <div class = "text-base ">
                <a href = "#icon">
                    <img src = "" alt = "icon"/>
                </a>
            </div>
            <div>
                <HamMenu client:load/>
            </div>
        </nav>
    </div>
</div>


