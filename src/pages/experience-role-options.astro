---
import Layout from '../layouts/Layout.astro';

const coreBullets = [
	'Manage building and surveying project delivery across multiple properties, coordinating leasing, operations, and property-management teams.',
	'Lead technical planning, consultant coordination, and execution tracking to keep construction work aligned with compliance, cost, and schedule requirements.',
	'Own the primary day-to-day responsibility in the built-environment domain rather than a software delivery function.',
];

const softwareBullets = [
	'Identify recurring operational friction and turn it into software opportunities inside the business.',
	'Prototype internal tools and AI workflows that support the surveying and project-management function.',
	'Work with users and IT stakeholders to test practical software ideas without presenting the role as a full-time software PM track.',
];

const softwareCards = [
	{
		title: 'Internal Tooling and Workflow Automation',
		period: '2022 - Present',
		scope: 'Software Initiative',
		description:
			'Designed and built internal tools that reduced repetitive manual work and improved operational visibility.',
	},
	{
		title: 'AI and Automation Solution Prototyping',
		period: '2025 - Present',
		scope: 'Software Initiative',
		description:
			'Built architecture concepts and lightweight demos to help stakeholders evaluate practical AI use cases.',
	},
];
---

<Layout>
	<main class="min-h-screen bg-slate-50 text-slate-900">
		<div class="mx-auto max-w-6xl px-6 py-12 md:px-10 md:py-16">
			<div class="max-w-3xl">
				<p class="text-sm font-semibold uppercase tracking-[0.18em] text-blue-700">Experience Role Split Preview</p>
				<h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-900">Core || Software</h1>
				<p class="mt-4 text-base leading-7 text-slate-600">
					These mockups test ways to make the two sides of your current role immediately obvious before anyone reads the detailed copy.
				</p>
			</div>

			<div class="mt-10 grid gap-8">
				<section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm md:p-8">
					<div class="flex items-center justify-between gap-4 border-b border-slate-200 pb-4">
						<div>
							<p class="text-sm font-semibold uppercase tracking-[0.16em] text-slate-500">Option 1</p>
							<h2 class="mt-1 text-2xl font-semibold text-slate-900">Segmented Switch</h2>
						</div>
						<p class="max-w-xl text-sm leading-6 text-slate-500">A single paired control makes the split obvious immediately, while only one content body is shown at a time.</p>
					</div>

					<div class="mt-6 rounded-2xl border border-slate-200 bg-slate-50 p-5">
						<div class="inline-grid w-full max-w-md grid-cols-2 overflow-hidden rounded-2xl border border-slate-300 bg-white shadow-sm">
							<div class="bg-blue-600 px-5 py-3 text-center font-semibold uppercase tracking-[0.16em] text-white">Core</div>
							<div class="px-5 py-3 text-center font-semibold uppercase tracking-[0.16em] text-slate-500">Software</div>
						</div>

						<div class="mt-6 max-w-3xl">
							<p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Primary role in building and surveying delivery</p>
							<div class="mt-4 space-y-4">
								{coreBullets.map((item) => (
									<div class="flex items-start gap-3">
										<span class="mt-2 h-2 w-2 rounded-full bg-blue-500"></span>
										<p class="text-sm leading-7 text-slate-700">{item}</p>
									</div>
								))}
							</div>
						</div>
					</div>
				</section>

				<section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm md:p-8">
					<div class="flex items-center justify-between gap-4 border-b border-slate-200 pb-4">
						<div>
							<p class="text-sm font-semibold uppercase tracking-[0.16em] text-slate-500">Option 2</p>
							<h2 class="mt-1 text-2xl font-semibold text-slate-900">Permanent Split Columns</h2>
						</div>
						<p class="max-w-xl text-sm leading-6 text-slate-500">Both sides stay visible at once. This is the clearest option if you want the dual nature of the role to read instantly.</p>
					</div>

					<div class="mt-6 grid gap-5 md:grid-cols-2">
						<div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
							<div class="flex items-center gap-3">
								<span class="inline-flex rounded-full bg-slate-900 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-white">Core</span>
								<p class="text-sm font-medium text-slate-500">Primary responsibility</p>
							</div>
							<div class="mt-5 space-y-4">
								{coreBullets.map((item) => (
									<div class="flex items-start gap-3">
										<span class="mt-2 h-2 w-2 rounded-full bg-slate-400"></span>
										<p class="text-sm leading-7 text-slate-700">{item}</p>
									</div>
								))}
							</div>
						</div>

						<div class="rounded-2xl border border-blue-100 bg-blue-50/50 p-5">
							<div class="flex items-center gap-3">
								<span class="inline-flex rounded-full bg-blue-600 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-white">Software</span>
								<p class="text-sm font-medium text-blue-700">Parallel initiative track</p>
							</div>
							<div class="mt-5 space-y-4">
								{softwareBullets.map((item) => (
									<div class="flex items-start gap-3">
										<span class="mt-2 h-2 w-2 rounded-full bg-blue-500"></span>
										<p class="text-sm leading-7 text-slate-700">{item}</p>
									</div>
								))}
							</div>
						</div>
					</div>
				</section>

				<section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm md:p-8">
					<div class="flex items-center justify-between gap-4 border-b border-slate-200 pb-4">
						<div>
							<p class="text-sm font-semibold uppercase tracking-[0.16em] text-slate-500">Option 3</p>
							<h2 class="mt-1 text-2xl font-semibold text-slate-900">Dual-Lane Header + Cards</h2>
						</div>
						<p class="max-w-xl text-sm leading-6 text-slate-500">The two lanes are declared immediately in the header, then the software lane gets richer card treatment while the core lane stays simpler.</p>
					</div>

					<div class="mt-6 rounded-2xl border border-slate-200 overflow-hidden">
						<div class="grid md:grid-cols-2">
							<div class="border-b border-slate-200 bg-slate-100 px-5 py-4 md:border-b-0 md:border-r">
								<p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Core</p>
								<p class="mt-2 text-sm leading-6 text-slate-700">Building and surveying project delivery</p>
							</div>
							<div class="bg-blue-50 px-5 py-4">
								<p class="text-xs font-semibold uppercase tracking-[0.18em] text-blue-700">Software</p>
								<p class="mt-2 text-sm leading-6 text-slate-700">Internal tools, automation, and AI initiative work</p>
							</div>
						</div>
					</div>

					<div class="mt-6 grid gap-5 md:grid-cols-[0.95fr_1.05fr]">
						<div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
							<p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Core Responsibilities</p>
							<div class="mt-4 space-y-4">
								{coreBullets.map((item) => (
									<p class="border-l-2 border-slate-300 pl-4 text-sm leading-7 text-slate-700">{item}</p>
								))}
							</div>
						</div>

						<div class="space-y-4">
							{softwareCards.map((item) => (
								<article class="rounded-2xl border border-blue-100 bg-blue-50/50 p-5">
									<div class="flex flex-wrap items-center gap-2">
										<h3 class="text-base font-semibold text-slate-900">{item.title}</h3>
										<span class="rounded-full bg-blue-100 px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] text-blue-700">{item.scope}</span>
									</div>
									<p class="mt-2 text-xs uppercase tracking-[0.16em] text-slate-500">{item.period}</p>
									<p class="mt-3 text-sm leading-7 text-slate-700">{item.description}</p>
								</article>
							))}
						</div>
					</div>
				</section>
			</div>
		</div>
	</main>
</Layout>