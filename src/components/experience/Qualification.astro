---
import QualficationCard from './QualificationCard'
const baseUrl = import.meta.env.BASE_URL.endsWith('/')
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
---

<section id="qualification" class="mt-8"> 
    <div class = "max-w-3xl">
        <h3
            class = "text-xs font-semibold tracking-wider text-gray-500 uppercase"
        >Certifications</h3>
    </div>
    <div class = "max-w-3xl mt-3 border-l-2 border-blue-200 space-y-4">
        <QualficationCard
            client:visible
            title = "AWS Certified Solutions Architect - Associate"
            img = {`${baseUrl}AWS%20badge.png`}
            date = "Nov 2024"
        />
        <QualficationCard
            client:visible
            title = "CS50"
            img = {`${baseUrl}CS50x.png`}
            date = "Oct 2023"
        />
    </div>
</section>