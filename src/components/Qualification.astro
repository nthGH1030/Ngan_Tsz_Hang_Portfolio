        <h1 class = "whitespace-nowrap font-bold text-xl md:3xl">3. Qualification</h1>
        <div class = "w-full bg-gray-300 h-px ml-2"></div>
    </div>
    <div class = "mx-8 md:mx-25">
        
        <QualficationCard
            client:visible
            title = "AWS Certified Solutions Architect-  Associate"
            img = "/AWS badge.png"
            date = "Nov 2024"
        />
        <QualficationCard
            client:visible
            title = "CS50"
            img = "/CS50x.png"
            date = "Oct 2023"
        />
    </div>
</section>