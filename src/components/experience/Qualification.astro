---
import QualficationCard from './QualificationCard'
---

<section id="qualification" class="mt-8"> 
    <div class = "max-w-3xl">
        <h3
            class = "text-xs font-semibold tracking-wider text-gray-500 uppercase"
            style = "font-family: 'Barlow', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;"
        >Certifications</h3>
    </div>
    <div class = "mt-3 max-w-3xl border-l-2 border-blue-200 pl-4 md:pl-6 space-y-4">
        <QualficationCard
            client:visible
            title = "AWS Certified Solutions Architect - Associate"
            img = "/AWS badge.png"
            date = "Nov 2024"
        />
        <QualficationCard
            client:visible
            title = "CS50"
            img = "/CS50x.png"
            date = "Oct 2023"
        />
    </div>
</section>