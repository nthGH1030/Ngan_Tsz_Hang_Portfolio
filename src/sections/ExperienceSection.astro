---
import Qualification from '../components/experience/Qualification.astro'
import ExperienceTabs from '../islands/ExperienceTabs'
---
<section id="experience" class="snap-start pt-24 overflow-y-auto h-screen">
    <div class = "mx-8 md:mx-24 flex items-center">
        <h1 class = "whitespace-nowrap font-bold text-xl md:text-2xl">2. Experience</h1>
        <div class = "w-full bg-gray-300 h-px ml-2"></div>
    </div>
    
    <div class = "mx-8 md:mx-24 mt-8">
        <ExperienceTabs client:load />
    </div>
    
    <div class = "mx-8 md:mx-24 pb-8">
        <Qualification/>
    </div>
</section>

<script>
    // Reset scroll position when section comes into view
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) entry.target.scrollTop = 0;
        });
    }, { threshold: 0.5 });
    
    const section = document.getElementById('experience');
    if (section) observer.observe(section);
</script>