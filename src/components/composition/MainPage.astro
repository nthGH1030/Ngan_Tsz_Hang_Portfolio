---
import TopBar from './navigation/TopBar.astro'
import BottomBar from './navigation/BottomBar.tsx'
import HomeSection from '../sections/HomeSection.astro'
import AboutSection from '../sections/AboutSection.astro'
import ExperienceSection from '../sections/ExperienceSection.astro'
import FeaturedWorkSection from '../sections/FeaturedWorkSection.astro'
import OtherProjectsSection from '../sections/OtherProjectsSection.astro'
import ContactSection from '../sections/ContactSection.astro'
---

<div >
    <div id = "top-bar">
        <TopBar/>
    </div>
    <div 
        id = 'snapContainer'
        class="snap-y snap-mandatory h-screen overflow-y-scroll">
        <HomeSection/>
        <AboutSection/>
        <ExperienceSection/>
        <FeaturedWorkSection/>
        <OtherProjectsSection/>
        <ContactSection/>
        <BottomBar/>
    </div>
</div>

<script>
    let lastState = false;
    let lastYCoor = 0
    const sectionScrollMap = new Map<Element, number>();
    
    const handleScroll = (scrollY: number) => {
        const bar = document.getElementById('top-bar');
        if(!bar) return;
        
        if(scrollY > lastYCoor){
            if(!lastState){
                bar.classList.remove('topbar-slide-in')
                bar.classList.add('topbar-slide-out')
                lastState = true
            } 
        } else if (scrollY < lastYCoor) {
            if(lastState ){
                bar.classList.remove('topbar-slide-out')
                bar.classList.add('topbar-slide-in')
                lastState = false
            }
        }
        lastYCoor = scrollY;
    }

    const handleOverflowScroll = (section: Element) => {
        const bar = document.getElementById('top-bar');
        if(!bar) return;
        
        const currentScroll = section.scrollTop;
        const lastSectionScroll = sectionScrollMap.get(section) || 0;
        
        // Always allow slide-out (scrolling down)
        if (currentScroll > lastSectionScroll && !lastState) {
            bar.classList.remove('topbar-slide-in')
            bar.classList.add('topbar-slide-out')
            lastState = true
        }
        // Only allow slide-in when at the top (scrolling up to top)
        else if (currentScroll === 0 && lastState) {
            bar.classList.remove('topbar-slide-out')
            bar.classList.add('topbar-slide-in')
            lastState = false
        }
        
        // Track last coor of the overflow section
        sectionScrollMap.set(section, currentScroll);
    }
    
    window.addEventListener('DOMContentLoaded' , () => {
        const snapContainer = document.getElementById('snapContainer');
        const bar = document.getElementById('top-bar');
        if(!snapContainer || !bar) return
        
        // Track main container scroll
        snapContainer.addEventListener('scroll' , () => {
            handleScroll(snapContainer.scrollTop);
        })
        
        // Track overflow sections scroll
        const overflowSections = document.querySelectorAll('.overflow-y-auto');
        overflowSections.forEach(section => {
            sectionScrollMap.set(section, 0); 
            section.addEventListener('scroll', () => {
                handleOverflowScroll(section);
            });
        });
    })

</script>