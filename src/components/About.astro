---

import "../styles/global.css";
import { IoIosArrowForward } from "react-icons/io";
---

<section id="about" class = "h-screen snap-start pt-32 overflow-y-auto max-w-screen-xl mx-auto" >
    <div class = "px-[clamp(2rem,15vw,24rem)] flex items-center">
        <h1 class = "whitespace-nowrap font-bold text-xl md:text-2xl">1. About me</h1>
        <div class = "w-full bg-gray-300 h-px ml-2"></div>
    </div>
    <div class = "flex flex-col gap-4 px-[clamp(2rem,15vw,24rem)] mt-8 md:gap-8 md:flex-row">
        <div class = "flex-1 min-w-0">
            <p class = "text-[clamp(0.8rem,2.5vw,1.1rem)]"> 
                I am a chartered building surveyor turned software engineer, 
                passionate about leveraging technology to solve real-world problems. 
                In my free time, I have developed and deployed solutions that address 
                challenges encountered in my professional work, some of which have been 
                adopted to enhance productivity and support educational initiatives. 
                I actively contribute to brainstorming sessions focused on automation and 
                AI adoption within the enterprise, identifying practical use cases 
                and creating technical demos to drive innovation and efficiency.
            </p>
            <br/>
            <p> I had work with the following technologies recently:</p>
            <div class = "grid grid-cols-2 gap-2 mt-4 mb-4">
                <div class = "flex items-center justify-start">
                    <IoIosArrowForward/>
                    <p>Javascript</p>
                </div>
                <div class = "flex items-center justify-start">
                    <IoIosArrowForward/>
                    <p>Typescript</p>
                </div>
                <div class = "flex items-center justify-start">
                    <IoIosArrowForward/>
                    <p>Node.js</p>
                </div>
                <div class = "flex items-center justify-start">
                    <IoIosArrowForward/>
                    <p>ReactJS</p>
                </div>
                <div class = "flex items-center justify-start">
                    <IoIosArrowForward/>
                    <p>Tailwind</p>
                </div>
                <div class = "flex items-center justify-start">
                    <IoIosArrowForward/>
                    <p>astro</p>
                </div>
                <div class = "flex items-center justify-start">
                    <IoIosArrowForward/>
                    <p>HTML</p>
                </div>
                <div class = "flex items-center justify-start">
                    <IoIosArrowForward/>
                    <p>CSS</p>
                </div>
                <div class = "flex items-center justify-start">
                    <IoIosArrowForward/>
                    <p>openAI</p>
                </div>
            </div>
        </div>
        <div class = "relative flex-shrink-0 mx-auto md:mx-0 self-start">
            <img
                src = "./portrait.jpg"
                alt = "portrait"
                class = "w-[clamp(150px,25vw,300px)] h-auto object-cover rounded-lg block"
            />
            <div class = "absolute inset-0 bg-blue-500/30 rounded-lg pointer-events-none"></div>
        </div>
    </div>
</section>