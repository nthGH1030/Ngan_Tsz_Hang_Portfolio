---
import TopBar from '../navigation/TopBar.astro'
import BottomBar from '../navigation/BottomBar.tsx'
import HomeSection from '../../sections/HomeSection.astro'
import AboutSection from '../../sections/AboutSection.astro'
import ExperienceSection from '../../sections/ExperienceSection.astro'
import FeaturedWorkSection from '../../sections/FeaturedWorkSection.astro'
import OtherProjectsSection from '../../sections/OtherProjectsSection.astro'
import ContactSection from '../../sections/ContactSection.astro'
---

<div >
    <div id = "top-bar">
        <TopBar/>
    </div>
    <div 
        id = 'snapContainer'
        class="h-screen overflow-y-scroll overscroll-y-contain snap-y snap-mandatory">
        <HomeSection/>
        <AboutSection/>
        <ExperienceSection/>
        <FeaturedWorkSection/>
        <OtherProjectsSection/>
        <ContactSection/>
        <BottomBar/>
    </div>
</div>

<script>
    const initializeSnapContainer = () => {
        const snapContainer = document.getElementById('snapContainer');
        const topBar = document.getElementById('top-bar');

        if (!(snapContainer instanceof HTMLElement) || !(topBar instanceof HTMLElement)) {
            return;
        }

        const lastScrollMap = new WeakMap<HTMLElement, number>();
        let isBarHidden = false;

        const hideBar = () => {
            if (isBarHidden) {
                return;
            }

            topBar.classList.remove('topbar-slide-in');
            topBar.classList.add('topbar-slide-out');
            isBarHidden = true;
        };

        const showBar = () => {
            if (!isBarHidden) {
                return;
            }

            topBar.classList.remove('topbar-slide-out');
            topBar.classList.add('topbar-slide-in');
            isBarHidden = false;
        };

        const handleDirectionalScroll = (source: HTMLElement) => {
            const prev = lastScrollMap.get(source) ?? source.scrollTop;
            const next = source.scrollTop;

            if (next > prev) {
                hideBar();
            } else if (next < prev) {
                showBar();
            }

            lastScrollMap.set(source, next);
        };

        lastScrollMap.set(snapContainer, snapContainer.scrollTop);
        snapContainer.addEventListener('scroll', () => handleDirectionalScroll(snapContainer), { passive: true });
    };

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initializeSnapContainer, { once: true });
    } else {
        initializeSnapContainer();
    }
</script>