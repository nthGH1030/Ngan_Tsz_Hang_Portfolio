---
import TopBar from '../navigation/TopBar.astro'
import BottomBar from '../navigation/BottomBar.tsx'
import HomeSection from '../../sections/HomeSection.astro'
import AboutSection from '../../sections/AboutSection.astro'
import ExperienceSection from '../../sections/ExperienceSection.astro'
import FeaturedWorkSection from '../../sections/FeaturedWorkSection.astro'
import OtherProjectsSection from '../../sections/OtherProjectsSection.astro'
import ContactSection from '../../sections/ContactSection.astro'
---

<div >
    <div id = "top-bar">
        <TopBar/>
    </div>
    <div 
        id = 'snapContainer'
        class="h-screen overflow-y-scroll overscroll-y-contain scroll-smooth snap-y snap-mandatory">
        <HomeSection/>
        <AboutSection/>
        <ExperienceSection/>
        <FeaturedWorkSection/>
        <OtherProjectsSection/>
        <ContactSection/>
        <BottomBar/>
    </div>
</div>

<script>
    const initializeSnapContainer = () => {
        const snapContainer = document.getElementById('snapContainer');

        if (!(snapContainer instanceof HTMLElement)) {
            return;
        }

        const mainSections = Array.from(
            snapContainer.querySelectorAll<HTMLElement>(':scope > [data-main-section]')
        );

        if (mainSections.length === 0) {
            return;
        }

        const orderedSectionIds = mainSections
            .map((section) => section.id)

        let activeSectionId = orderedSectionIds[0] ?? '';
        let isSnappingBetweenSections = false;
        let snapDirection: 'up' | 'down' | null = null;
        let lastScrollTop = snapContainer.scrollTop;
        let settleTimer = 0;

        const emitSnapState = (eventName: string) => {
            snapContainer.dataset.activeSection = activeSectionId;
            snapContainer.dataset.isSnapping = String(isSnappingBetweenSections);

            if (snapDirection) {
                snapContainer.dataset.snapDirection = snapDirection;
            } else {
                delete snapContainer.dataset.snapDirection;
            }

            mainSections.forEach((section) => {
                section.dataset.active = String(section.id === activeSectionId);
            });

            window.dispatchEvent(new CustomEvent(eventName, {
                detail: {
                    orderedSectionIds,
                    activeSectionId,
                    isSnappingBetweenSections,
                    snapDirection,
                },
            }));
        };

        const getClosestSection = () => {
            return mainSections.reduce((closestSection, section) => {
                if (!(section instanceof HTMLElement) || !(closestSection instanceof HTMLElement)) {
                    return closestSection;
                }

                const currentDistance = Math.abs(section.offsetTop - snapContainer.scrollTop);
                const closestDistance = Math.abs(closestSection.offsetTop - snapContainer.scrollTop);

                return currentDistance < closestDistance ? section : closestSection;
            }, mainSections[0]);
        };

        const settleActiveSection = () => {
            const nextSection = getClosestSection();

            if (!(nextSection instanceof HTMLElement)) {
                return;
            }

            const settledDirection = snapDirection;

            activeSectionId = nextSection.id;
            isSnappingBetweenSections = false;
            snapDirection = settledDirection;
            emitSnapState('main-section-settled');
            snapDirection = null;
            delete snapContainer.dataset.snapDirection;
        };

        emitSnapState('main-section-ready');

        snapContainer.addEventListener('scroll', () => {
            const nextScrollTop = snapContainer.scrollTop;
            const nextDirection = nextScrollTop > lastScrollTop
                ? 'down'
                : nextScrollTop < lastScrollTop
                    ? 'up'
                    : snapDirection;

            if (!nextDirection) {
                return;
            }

            snapDirection = nextDirection;
            isSnappingBetweenSections = true;
            emitSnapState('main-section-snap-start');

            window.clearTimeout(settleTimer);
            settleTimer = window.setTimeout(settleActiveSection, 140);
            lastScrollTop = nextScrollTop;
        }, { passive: true });
    };

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initializeSnapContainer, { once: true });
    } else {
        initializeSnapContainer();
    }
</script>