---
import TopBar from '../navigation/TopBar.astro'
import BottomBar from '../navigation/BottomBar.tsx'
import HomeSection from '../../sections/HomeSection.astro'
import AboutSection from '../../sections/AboutSection.astro'
import ExperienceSection from '../../sections/ExperienceSection.astro'
import FeaturedWorkSection from '../../sections/FeaturedWorkSection.astro'
import OtherProjectsSection from '../../sections/OtherProjectsSection.astro'
import ContactSection from '../../sections/ContactSection.astro'
---

<div >
    <div id = "top-bar" class="relative z-[300]">
        <TopBar/>
    </div>
    <div aria-hidden="true" class="pointer-events-none fixed inset-x-0 top-0 z-[200] h-18 md:h-22">
        <div class="absolute inset-0 backdrop-blur-sm"></div>
        <div class="absolute inset-x-0 bottom-0 h-8 bg-gradient-to-b from-slate-100/25 to-transparent"></div>
    </div>
    <div 
        id = 'scrollContainer'
        class="relative z-0 h-screen overflow-y-scroll">
        <HomeSection/>
        <AboutSection/>
        <ExperienceSection/>
        <FeaturedWorkSection/>
        <OtherProjectsSection/>
        <ContactSection/>
        <BottomBar/>
    </div>
</div>

<script>
    const initializeScrollContainer = () => {
        const scrollContainer = document.getElementById('scrollContainer');
        const topBar = document.getElementById('top-bar');

        if (!(scrollContainer instanceof HTMLElement) || !(topBar instanceof HTMLElement)) {
            return;
        }

        const lastScrollMap = new WeakMap<HTMLElement, number>();
        let isBarHidden = false;

        const hideBar = () => {
            if (isBarHidden) {
                return;
            }

            topBar.classList.remove('topbar-slide-in');
            topBar.classList.add('topbar-slide-out');
            isBarHidden = true;
        };

        const showBar = () => {
            if (!isBarHidden) {
                return;
            }

            topBar.classList.remove('topbar-slide-out');
            topBar.classList.add('topbar-slide-in');
            isBarHidden = false;
        };

        const handleDirectionalScroll = (source: HTMLElement) => {
            const prev = lastScrollMap.get(source) ?? source.scrollTop;
            const next = source.scrollTop;

            if (next > prev) {
                hideBar();
            } else if (next < prev) {
                showBar();
            }

            lastScrollMap.set(source, next);
        };

        lastScrollMap.set(scrollContainer, scrollContainer.scrollTop);
        scrollContainer.addEventListener('scroll', () => handleDirectionalScroll(scrollContainer), { passive: true });
    };

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initializeScrollContainer, { once: true });
    } else {
        initializeScrollContainer();
    }
</script>