---
import Card from './Card'
import FeaturedCard from './FeaturedCard'
---

<section id="work" class = "snap-start h-screen pt-24" >
    <div class = "mx-2 sm:mx-4 md:mx-24 flex items-center">
        <h1 class = "whitespace-nowrap font-bold text-xl md:text-2xl">Other Projects</h1>
        <div class = "w-full bg-gray-300 h-px ml-2"></div>
    </div>
    <div class = " 
        grid grid-cols-1
        pt-4
        sm:grid-cols-1 sm:mx-4
        md:grid-cols-2 md:mx-24 
        mx-2
        gap-4  
        overflow-y-auto
        max-h-[calc(100vh-theme(spacing.24))]
        ">
        
        <Card
            client:visible
            title = "Lunch Roulette"
            content = {`A web app that recommand restaurants, categories by location, crusines
            . Spin the roulette to decide what to get for lunch!`}
            tagNames = {["JavaScript" , "Next.js", "React" , "Tailwind", "Vercel" , "Google Map API"]}
            href = {"https://lunch-roulette-phi.vercel.app/"}
            gitHref = {"placeholder"}
        />
        <Card
            client:visible
            title = "Landlord Provision Chatbot"
            content = {`A chatbot that recommand industry standard premise provision for 
            leasing commercial real estate, such as retail, restaurant`}
            tagNames = {["TypeScript" , "openAI" , "Azure"]}
            href = {"placeholder"}
            gitHref = {"placeholder"}
        />
        <Card
            client:visible
            title = "LLM-Token-Checker"
            content = {`A chrome extension that tracks the amount of free token you have
            and refresh time for LLM chatbot such as POE.com, Grok`}
            tagNames = {["JavaScript" , "React" , "Chrome Extension"]}
            href = {"https://github.com/nthGH1030/LLM-Token-Tracker.git"}
            gitHref = {"https://github.com/nthGH1030/LLM-Token-Tracker.git"}
        />
        <div id="payment-form-filler">
            <Card
                client:visible
                title = "Payment Form filler"
                content = {`An desktop Application that takes in a master table in an excel file,
                extract its content, check the format and paste onto a separate excel form`}
                tagNames = {["JavaScript" , "Electron", "React", "CSS" , "HTML"]}
                href = {"placeholder"}
                gitHref = {"placeholder"}
            />
        </div>
    </div>
</section>